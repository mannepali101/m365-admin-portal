# ============================================================
# M365 Admin Portal - Frontend Environment Variables
# Copy to .env.local — never commit the real .env.local file
# ============================================================

# --- Backend API ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Microsoft Entra ID ---
# Same Tenant ID as your backend
NEXT_PUBLIC_AZURE_TENANT_ID=your-tenant-id-here

# Same Client ID (App Registration)
NEXT_PUBLIC_AZURE_CLIENT_ID=your-client-id-here

# Must match the redirect URI registered in Azure Portal
# Format: http://localhost:3000/auth/callback  (dev)
#         https://yourdomain.com/auth/callback (prod)
NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

# --- App Metadata ---
NEXT_PUBLIC_APP_NAME=M365 Admin Portal

# ============================================================
# In Azure Portal > App Registrations > Authentication:
#   Add platform: Single-page application
#   Redirect URI: http://localhost:3000/auth/callback
#   Logout URL:   http://localhost:3000/login
#   Allow implicit grant: ID tokens ✓, Access tokens ✓
# ============================================================
