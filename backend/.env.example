# ============================================================
# M365 Admin Portal - Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=4000

# --- CORS ---
# The URL of your Next.js frontend
FRONTEND_URL=http://localhost:3000

# --- Microsoft Entra ID (Azure AD) ---
# From: Azure Portal > App Registrations > Your App
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Session Security ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-64-char-random-hex-string

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-32-char-random-hex-string

# --- Logging ---
LOG_LEVEL=info

# ============================================================
# Microsoft Graph API Permissions Required (Delegated):
#   User.ReadWrite.All
#   Group.ReadWrite.All
#   DeviceManagementManagedDevices.ReadWrite.All
#   Reports.Read.All
#   AuditLog.Read.All
#   Directory.ReadWrite.All
#   Sites.ReadWrite.All
#   Team.ReadBasic.All
#   offline_access, openid, profile, email
# ============================================================
